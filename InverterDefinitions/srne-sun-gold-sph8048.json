  "derivedReadings": [
    {
      "key": "load_apparent_power_total",
      "name": "Load Apparent Power Total",
      "group": "Power",
      "unit": "VA",
      "operation": "sum",
      "sources": [ "load_apparent_power_leg_1", "load_apparent_power_leg_2" ],
      "notes": "Calculated as leg 1 VA + leg 2 VA for 120-N-120 split-phase output."
    },
    {
      "key": "load_real_power_leg_1_estimate",
      "name": "Load Real Power Leg 1 Estimate",
      "group": "Power",
      "unit": "W",
      "operation": "product",
      "sources": [ "load_apparent_power_leg_1", "load_power_factor" ],
      "notes": "Estimated as leg 1 apparent power * shared load power factor."
    },
    {
      "key": "load_real_power_leg_2_estimate",
      "name": "Load Real Power Leg 2 Estimate",
      "group": "Power",
      "unit": "W",
      "operation": "product",
      "sources": [ "load_apparent_power_leg_2", "load_power_factor" ],
      "notes": "Estimated as leg 2 apparent power * shared load power factor."
    },
    {
      "key": "load_real_power_estimate",
      "name": "Load Real Power Estimate",
      "group": "Power",
      "unit": "W",
      "operation": "product",
      "sources": [ "load_apparent_power_total", "load_power_factor" ],
      "notes": "Calculated as total apparent power * load power factor."
    }
