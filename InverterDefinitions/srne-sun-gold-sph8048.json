{
  "id": "srne-sun-gold-sph8048",
  "brand": "SRNE / Sun Gold Power",
  "model": "SPH8048",
  "description": "Initial register map ported from the working ESPHome configuration and live-tested against the Waveshare RTU-over-TCP bridge.",
  "protocol": {
    "transport": "rtuOverTcp",
    "slaveId": 1,
    "baudRate": 9600,
    "dataBits": 8,
    "parity": "none",
    "stopBits": 1
  },
  "readBehavior": {
    "registerType": "holding",
    "maxBlockSize": 16,
    "maxGapWithinBlock": 4,
    "delayBetweenBlocksMs": 80
  },
